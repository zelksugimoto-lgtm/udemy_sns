# Database
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=social_media_db

# Server
PORT=8080
ENV=development
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=168h

# Admin Panel
ADMIN_ROOT_USERNAME=admin
ADMIN_ROOT_PASSWORD=change-me-in-production
ADMIN_SESSION_SECRET=your-session-secret-key-change-in-production

# E2E Testing (WARNING: Only enable in test environments!)
# When set to "true", new users are automatically approved without admin review
# NEVER enable this in production as it bypasses user approval security
AUTO_APPROVE_USERS=false

# Firebase (Phase 2で使用)
# FIREBASE_SERVICE_ACCOUNT_KEY: Firebaseサービスアカウントキー（JSON文字列）
# 設定方法: Firebase Console > Project Settings > Service Accounts > Generate new private key
# ダウンロードしたJSONファイルの内容を1行の文字列として設定
# 例: FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...",...}'
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-bucket.appspot.com

# File Upload (Phase 2で使用)
MAX_VIDEO_SIZE_MB=20
MAX_IMAGE_SIZE_MB=5
MAX_UPLOAD_FILES=4
