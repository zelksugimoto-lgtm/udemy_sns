# Database
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=social_media_db

# Server
PORT=8080
ENV=development
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=168h

# Admin Panel
ADMIN_ROOT_USERNAME=admin
ADMIN_ROOT_PASSWORD=admin123
ADMIN_SESSION_SECRET=dev-session-secret-key-12345

# E2E Testing (WARNING: Only enable in test environments!)
# When set to "true", new users are automatically approved without admin review
# NEVER enable this in production as it bypasses user approval security
AUTO_APPROVE_USERS=false

# Firebase (Phase 2で使用)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-bucket

# File Upload (Phase 2で使用)
MAX_VIDEO_SIZE_MB=20
MAX_IMAGE_SIZE_MB=5
MAX_UPLOAD_FILES=4
